VITE_API_BASE=/api

# MySQL / cloud MySQL connection.
# Free cloud options that work with this shape include Aiven for MySQL and TiDB Cloud Serverless.
# Use DATABASE_URL when your cloud provider gives a single connection string.
DATABASE_URL=

# Or use local MySQL fields.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=SchoolStudyroomReservation
DB_SSL=false

API_PORT=3001
